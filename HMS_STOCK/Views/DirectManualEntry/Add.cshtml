@{
    ViewBag.Title = "Manual Entry - Add";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    body {
        background-color: #f8f9fa;
    }

    .page-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 20px;
        border-radius: 10px;
        margin-bottom: 20px;
    }

    .page-title {
        font-size: 28px;
        font-weight: 700;
        margin: 0;
        display: flex;
        align-items: center;
    }

    .page-title i {
        margin-right: 10px;
        font-size: 24px;
    }

    .content-card {
        background: white;
        border-radius: 10px;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.07);
        padding: 20px;
        margin-bottom: 20px;
    }
</style>

<div class="container-fluid">
    <div class="page-header">
        <h1 class="page-title"><i class="bi bi-vector-pen"></i> Manual Stock Entry - Add</h1>
    </div>

    <div class="content-card">
        @using (Html.BeginForm("Add", "DirectManualEntry", FormMethod.Post))
        {
            @Html.AntiForgeryToken()

            <div class="alert alert-info">
                Add form will be implemented.
            </div>

            <div class="d-flex justify-content-end">
                <a href="@Url.Action("Index", "DirectManualEntry")" class="btn btn-secondary mr-2">Back</a>
                <button type="submit" class="btn btn-primary">Save</button>
            </div>
        }
    </div>
</div>
