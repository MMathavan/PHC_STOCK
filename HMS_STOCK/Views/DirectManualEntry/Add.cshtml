@{
    ViewBag.Title = "Manual Entry - Add";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .main-container {
        background: white;
        min-height: 100vh;
        padding: 20px 0;
    }

    .content-wrapper {
        background: white;
        border-radius: 15px;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        margin: 20px;
        overflow: hidden;
        border: 1px solid #e9ecef;
    }

    .page-header-bar {
        background: linear-gradient(90deg, #2bb7ff 0%, #00e5ff 100%);
        color: white;
        padding: 14px 18px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
    }

    .page-title {
        margin: 0;
        font-weight: 700;
        font-size: 16px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .form-container {
        padding: 22px 30px 26px 30px;
        background: white;
    }

    .form-label {
        font-weight: 600;
        color: #495057;
        margin-bottom: 8px;
        font-size: 13px;
        display: block;
    }

    .select2-container { width: 100% !important; }

    .select2-container--default .select2-selection--single {
        height: 42px;
        border: 1px solid #ced4da;
        border-radius: 8px;
        display: flex;
        align-items: center;
        padding: 0 10px;
    }

    .select2-container--default .select2-selection--single .select2-selection__rendered {
        line-height: 40px;
        padding-left: 0;
        color: #495057;
    }

    .select2-container--default .select2-selection--single .select2-selection__arrow {
        height: 40px;
    }

    .form-actions-row {
        display: flex;
        justify-content: space-between;
        gap: 10px;
        margin-top: 20px;
    }

    .field-error {
        color: #dc3545;
        font-size: 12px;
        margin-top: 6px;
        display: none;
    }

    .has-error {
        border-color: #dc3545 !important;
    }

    .field-card {
        background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
        border-radius: 10px;
        padding: 16px;
        border: 1px solid #dee2e6;
        margin-top: 16px;
    }

    .field-card-title {
        font-weight: 700;
        font-size: 13px;
        color: #495057;
        margin-bottom: 12px;
        text-transform: uppercase;
        letter-spacing: .6px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .readonly-input {
        background: #ffffff;
        border: 1px solid #ced4da;
        border-radius: 8px;
        padding: 10px 12px;
        font-size: 13px;
        width: 100%;
    }

    .readonly-input:focus {
        outline: none;
        box-shadow: none;
        border-color: #ced4da;
    }

    .swal-small-popup {
        width: 420px !important;
        padding: 18px 18px 14px 18px !important;
        border-radius: 12px !important;
    }

    .swal-small-title {
        font-size: 22px !important;
        margin-top: 6px !important;
    }

    .swal-small-actions {
        gap: 10px !important;
    }

    .swal-small-confirm {
        background: #5a67d8 !important;
        color: #fff !important;
        border: none !important;
        border-radius: 8px !important;
        padding: 8px 14px !important;
        font-weight: 600 !important;
        font-size: 13px !important;
        min-width: 96px;
    }

    .swal-small-cancel {
        background: #6c757d !important;
        color: #fff !important;
        border: none !important;
        border-radius: 8px !important;
        padding: 8px 14px !important;
        font-weight: 600 !important;
        font-size: 13px !important;
        min-width: 96px;
    }
</style>

@section Styles {
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
}

<div class="main-container">
    <div class="content-wrapper">
        <div class="page-header-bar">
            <h3 class="page-title">
                <i class="bi bi-vector-pen"></i> Manual Stock Entry - @(ViewBag.IsEdit != null && (bool)ViewBag.IsEdit ? "Edit" : "Add")
            </h3>
        </div>

        <div class="form-container">
            @using (Html.BeginForm(ViewBag.IsEdit != null && (bool)ViewBag.IsEdit ? "Edit" : "Add", "DirectManualEntry", FormMethod.Post))
            {
                @Html.AntiForgeryToken()

                if (ViewBag.IsEdit != null && (bool)ViewBag.IsEdit)
                {
                    <input type="hidden" name="SID" value="@ViewBag.SID" />
                }

                if (ViewBag.ErrorMessage != null)
                {
                    <div class="alert alert-danger">@ViewBag.ErrorMessage</div>
                }

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label for="mtrlid" class="form-label">Material</label>
                            @Html.DropDownList("mtrlid", (SelectList)ViewBag.Materials, "-- Select Material --", new { @class = "form-control", id = "mtrlid" })
                            <div id="mtrlid_error" class="field-error">Please select a Material.</div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label for="materialGroupName" class="form-label">Material Group</label>
                            <input type="text" id="materialGroupName" class="readonly-input" readonly />
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label for="currentBatch" class="form-label">Current Batch</label>
                            <input type="text" id="currentBatch" name="currentBatch" class="form-control" autocomplete="off" value="@(ViewBag.CurrentBatch ?? string.Empty)" />
                            <div id="currentBatch_error" class="field-error">Please enter Current Batch.</div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label for="phyQty" class="form-label">Physical Quantity</label>
                            <input type="number" id="phyQty" name="phyQty" class="form-control" step="0.01" autocomplete="off" value="@(ViewBag.PhyQty ?? string.Empty)" />
                            <div id="phyQty_error" class="field-error">Please enter Physical Quantity.</div>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label for="expiryDate" class="form-label">Expiry Date</label>
                            <input type="date" id="expiryDate" name="expiryDate" class="form-control" value="@(ViewBag.ExpiryDate ?? string.Empty)" />
                            <div id="expiryDate_error" class="field-error">Please select Expiry Date.</div>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-12">
                        <div class="field-card">
                            <div class="field-card-title"><i class="fa fa-database"></i> Opening Supplier HSN Details</div>
                            <div id="openingFields" class="row"></div>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-12">
                        <div class="field-card">
                            <div class="field-card-title"><i class="fa fa-database"></i> Material HSN Details</div>
                            <div id="materialFields" class="row"></div>
                        </div>
                    </div>
                </div>

                <div class="form-actions-row">
                    <a href="@Url.Action("Index", "DirectManualEntry")" class="btn btn-secondary">Back</a>
                    <button type="submit" class="btn btn-primary" id="btnSave">@(ViewBag.IsEdit != null && (bool)ViewBag.IsEdit ? "Update" : "Save")</button>
                </div>
            }
        </div>
    </div>
</div>

@section scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script>
        $(document).ready(function () {
            var $mtrl = $('#mtrlid');
            var $groupName = $('#materialGroupName');
            var $currentBatch = $('#currentBatch');
            var $phyQty = $('#phyQty');
            var $expiryDate = $('#expiryDate');
            var isEdit = @((ViewBag.IsEdit != null && (bool)ViewBag.IsEdit) ? "true" : "false");
            var isSubmitting = false;

            function setError($el, errorId, hasError) {
                if (hasError) {
                    $el.addClass('has-error');
                    $('#' + errorId).show();
                } else {
                    $el.removeClass('has-error');
                    $('#' + errorId).hide();
                }
            }

            function validateForm() {
                var ok = true;

                var mtrlVal = $mtrl.val();
                var hasMtrl = !!mtrlVal && parseInt(mtrlVal, 10) > 0;
                setError($mtrl.next('.select2').length ? $mtrl.next('.select2').find('.select2-selection') : $mtrl, 'mtrlid_error', !hasMtrl);
                if (!hasMtrl) ok = false;

                var cb = ($currentBatch.val() || '').trim();
                setError($currentBatch, 'currentBatch_error', cb.length === 0);
                if (cb.length === 0) ok = false;

                var pq = ($phyQty.val() || '').trim();
                var pqNum = pq.length ? Number(pq) : NaN;
                var pqInvalid = pq.length === 0 || isNaN(pqNum);
                setError($phyQty, 'phyQty_error', pqInvalid);
                if (pqInvalid) ok = false;

                var exp = ($expiryDate.val() || '').trim();
                setError($expiryDate, 'expiryDate_error', exp.length === 0);
                if (exp.length === 0) ok = false;

                return ok;
            }

            if ($.fn.select2) {
                $mtrl.select2({
                    placeholder: '-- Select Material --',
                    allowClear: true,
                    minimumResultsForSearch: 0,
                    width: '100%'
                });
            }

            function escapeHtml(s) {
                return String(s)
                    .replace(/&/g, '&amp;')
                    .replace(/</g, '&lt;')
                    .replace(/>/g, '&gt;')
                    .replace(/"/g, '&quot;')
                    .replace(/'/g, '&#39;');
            }

            function formatDateValue(v) {
                if (v === null || v === undefined) return '';

                if (Object.prototype.toString.call(v) === '[object Date]' && !isNaN(v.getTime())) {
                    var yyyy = v.getFullYear();
                    var mm = String(v.getMonth() + 1).padStart(2, '0');
                    var dd = String(v.getDate()).padStart(2, '0');
                    return yyyy + '-' + mm + '-' + dd;
                }

                var s = String(v);
                var m = /\/Date\((-?\d+)\)\//.exec(s);
                if (m && m[1]) {
                    var ms = parseInt(m[1], 10);
                    if (!isNaN(ms)) {
                        return formatDateValue(new Date(ms));
                    }
                }

                return s;
            }

            function renderFields(containerId, dataObj) {
                var $c = $('#' + containerId);
                $c.empty();
                if (!dataObj) return;

                var keys = Object.keys(dataObj);
                if (!keys.length) {
                    $c.append('<div class="col-12" style="color:#6c757d;font-size:13px;">No data found</div>');
                    return;
                }

                for (var i = 0; i < keys.length; i++) {
                    var k = keys[i];
                    var v = dataObj[k];
                    var safeK = escapeHtml(k);
                    var displayV = (v === null || v === undefined) ? '' : v;
                    if (k && String(k).toUpperCase().indexOf('DATE') >= 0) {
                        displayV = formatDateValue(displayV);
                    } else if (typeof displayV === 'string' && /\/Date\((-?\d+)\)\//.test(displayV)) {
                        displayV = formatDateValue(displayV);
                    }
                    var safeV = (displayV === null || displayV === undefined) ? '' : escapeHtml(displayV);
                    var html = '';
                    html += '<div class="col-md-4" style="margin-bottom:12px;">';
                    html += '  <label class="form-label" style="margin-bottom:6px;font-size:12px;">' + safeK + '</label>';
                    html += '  <input type="text" class="readonly-input" readonly value="' + safeV + '" />';
                    html += '</div>';
                    $c.append(html);
                }
            }

            function clearDetails() {
                $('#openingFields').empty();
                $('#materialFields').empty();
                $groupName.val('');
            }

            function loadDetails(mtrlid) {
                clearDetails();
                if (!mtrlid) return;

                $.ajax({
                    url: '@Url.Action("GetMaterialDetails", "DirectManualEntry")',
                    type: 'GET',
                    data: { mtrlid: mtrlid },
                    success: function (res) {
                        if (!res || !res.ok) return;
                        if (res.group && res.group.MTRLGDESC) {
                            $groupName.val(res.group.MTRLGDESC);
                        } else {
                            $groupName.val('');
                        }
                        renderFields('openingFields', res.opening);
                        renderFields('materialFields', res.material);
                    }
                });
            }

            $mtrl.on('change', function () {
                loadDetails($(this).val());
                validateForm();
            });

            $currentBatch.on('input', function () { validateForm(); });
            $phyQty.on('input', function () { validateForm(); });
            $expiryDate.on('change', function () { validateForm(); });

            $('form').on('submit', function (e) {
                if (isSubmitting) {
                    return;
                }

                if (!validateForm()) {
                    e.preventDefault();
                    return;
                }

                if (window.Swal && Swal.fire) {
                    e.preventDefault();

                    var title = isEdit ? 'Update this entry?' : 'Save this entry?';
                    var confirmText = isEdit ? 'Yes, Update' : 'Yes, Save';

                    Swal.fire({
                        icon: 'question',
                        title: title,
                        showCancelButton: true,
                        confirmButtonText: confirmText,
                        cancelButtonText: 'Cancel',
                        width: 420,
                        buttonsStyling: false,
                        customClass: {
                            popup: 'swal-small-popup',
                            title: 'swal-small-title',
                            actions: 'swal-small-actions',
                            confirmButton: 'swal-small-confirm',
                            cancelButton: 'swal-small-cancel'
                        }
                    }).then(function (result) {
                        if (result && result.isConfirmed) {
                            isSubmitting = true;
                            try {
                                $('#btnSave').prop('disabled', true);
                            } catch (ex) { }
                            e.target.submit();
                        }
                    });
                }
            });

            var initialMtrl = $mtrl.val();
            if (initialMtrl && parseInt(initialMtrl, 10) > 0) {
                loadDetails(initialMtrl);
            } else {
                clearDetails();
            }
        });
    </script>
}
