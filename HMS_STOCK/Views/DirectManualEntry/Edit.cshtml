@model HMS_STOCK.Models.StockMaster_2526

@{
    ViewBag.Title = "Manual Entry - Edit";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="main-container">
    <div class="content-wrapper">
        <div class="page-header-bar" style="background: linear-gradient(90deg, #2bb7ff 0%, #00e5ff 100%); color: white; padding: 14px 18px; display:flex; align-items:center; justify-content:space-between; gap:12px;">
            <h3 class="page-title" style="margin:0; font-weight:700; font-size:16px; display:flex; align-items:center; gap:10px;">
                <i class="bi bi-vector-pen"></i> Manual Stock Entry - Edit
            </h3>
        </div>

        <div class="form-container" style="padding: 22px 30px 26px 30px; background: white;">
            @using (Html.BeginForm("Edit", "DirectManualEntry", FormMethod.Post))
            {
                @Html.AntiForgeryToken()
                @Html.HiddenFor(m => m.SID)

                if (ViewBag.ErrorMessage != null)
                {
                    <div class="alert alert-danger">@ViewBag.ErrorMessage</div>
                }

                <div class="row">
                    <div class="col-md-4 form-group">
                        @Html.LabelFor(m => m.TRANREFID)
                        @Html.TextBoxFor(m => m.TRANREFID, new { @class = "form-control" })
                    </div>
                    <div class="col-md-4 form-group">
                        @Html.LabelFor(m => m.TRANREFNAME)
                        @Html.TextBoxFor(m => m.TRANREFNAME, new { @class = "form-control" })
                    </div>
                    <div class="col-md-4 form-group">
                        @Html.LabelFor(m => m.TRANDREFGID)
                        @Html.TextBoxFor(m => m.TRANDREFGID, new { @class = "form-control" })
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-4 form-group">
                        @Html.LabelFor(m => m.MTRLGID)
                        @Html.TextBoxFor(m => m.MTRLGID, new { @class = "form-control" })
                    </div>
                    <div class="col-md-4 form-group">
                        @Html.LabelFor(m => m.MTRLGDESC)
                        @Html.TextBoxFor(m => m.MTRLGDESC, new { @class = "form-control" })
                    </div>
                    <div class="col-md-4 form-group">
                        @Html.LabelFor(m => m.MTRLDESC)
                        @Html.TextBoxFor(m => m.MTRLDESC, new { @class = "form-control" })
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-4 form-group">
                        @Html.LabelFor(m => m.DACHEADID)
                        @Html.TextBoxFor(m => m.DACHEADID, new { @class = "form-control" })
                    </div>
                    <div class="col-md-4 form-group">
                        @Html.LabelFor(m => m.PACKMID)
                        @Html.TextBoxFor(m => m.PACKMID, new { @class = "form-control" })
                    </div>
                    <div class="col-md-4 form-group">
                        @Html.LabelFor(m => m.BATCHNO)
                        @Html.TextBoxFor(m => m.BATCHNO, new { @class = "form-control" })
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-4 form-group">
                        @Html.LabelFor(m => m.STKEDATE)
                        @Html.TextBoxFor(m => m.STKEDATE, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date" })
                    </div>
                    <div class="col-md-4 form-group">
                        @Html.LabelFor(m => m.MTRLSTKQTY)
                        @Html.TextBoxFor(m => m.MTRLSTKQTY, new { @class = "form-control" })
                    </div>
                    <div class="col-md-4 form-group">
                        @Html.LabelFor(m => m.STKPRATE)
                        @Html.TextBoxFor(m => m.STKPRATE, new { @class = "form-control" })
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-4 form-group">
                        @Html.LabelFor(m => m.STKMRP)
                        @Html.TextBoxFor(m => m.STKMRP, new { @class = "form-control" })
                    </div>
                    <div class="col-md-4 form-group">
                        @Html.LabelFor(m => m.ASTKSRATE)
                        @Html.TextBoxFor(m => m.ASTKSRATE, new { @class = "form-control" })
                    </div>
                    <div class="col-md-4 form-group">
                        @Html.LabelFor(m => m.HSNID)
                        @Html.TextBoxFor(m => m.HSNID, new { @class = "form-control" })
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-4 form-group">
                        @Html.LabelFor(m => m.TRANBCGSTEXPRN)
                        @Html.TextBoxFor(m => m.TRANBCGSTEXPRN, new { @class = "form-control" })
                    </div>
                    <div class="col-md-4 form-group">
                        @Html.LabelFor(m => m.TRANBSGSTEXPRN)
                        @Html.TextBoxFor(m => m.TRANBSGSTEXPRN, new { @class = "form-control" })
                    </div>
                    <div class="col-md-4 form-group">
                        @Html.LabelFor(m => m.TRANBIGSTEXPRN)
                        @Html.TextBoxFor(m => m.TRANBIGSTEXPRN, new { @class = "form-control" })
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-4 form-group">
                        @Html.LabelFor(m => m.TRANBCGSTAMT)
                        @Html.TextBoxFor(m => m.TRANBCGSTAMT, new { @class = "form-control" })
                    </div>
                    <div class="col-md-4 form-group">
                        @Html.LabelFor(m => m.TRANBSGSTAMT)
                        @Html.TextBoxFor(m => m.TRANBSGSTAMT, new { @class = "form-control" })
                    </div>
                    <div class="col-md-4 form-group">
                        @Html.LabelFor(m => m.TRANBIGSTAMT)
                        @Html.TextBoxFor(m => m.TRANBIGSTAMT, new { @class = "form-control" })
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-4 form-group">
                        @Html.LabelFor(m => m.CLVALUE)
                        @Html.TextBoxFor(m => m.CLVALUE, new { @class = "form-control" })
                    </div>
                    <div class="col-md-4 form-group">
                        @Html.LabelFor(m => m.CURRENTBATCH)
                        @Html.TextBoxFor(m => m.CURRENTBATCH, new { @class = "form-control" })
                    </div>
                    <div class="col-md-4 form-group">
                        @Html.LabelFor(m => m.PHYQTY)
                        @Html.TextBoxFor(m => m.PHYQTY, new { @class = "form-control" })
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-4 form-group">
                        @Html.LabelFor(m => m.CUSRID)
                        @Html.TextBoxFor(m => m.CUSRID, new { @class = "form-control" })
                    </div>
                    <div class="col-md-4 form-group">
                        @Html.LabelFor(m => m.LMUSRID)
                        @Html.TextBoxFor(m => m.LMUSRID, new { @class = "form-control" })
                    </div>
                    <div class="col-md-4 form-group">
                        @Html.LabelFor(m => m.PRCSDATE)
                        @Html.TextBoxFor(m => m.PRCSDATE, "{0:yyyy-MM-ddTHH:mm}", new { @class = "form-control", type = "datetime-local" })
                    </div>
                </div>

                <div style="display:flex; justify-content:space-between; margin-top:20px;">
                    <a href="@Url.Action("Index", "DirectManualEntry")" class="btn btn-secondary">Back</a>
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                </div>
            }
        </div>
    </div>
</div>
