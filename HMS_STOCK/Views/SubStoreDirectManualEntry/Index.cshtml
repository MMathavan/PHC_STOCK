@model IEnumerable<HMS_STOCK.Models.SubStoreStockMaster_2526>

@{
    ViewBag.Title = "Manual Entry";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .main-container {
        background: white;
        min-height: 100vh;
        padding: 20px 0;
    }

    .content-wrapper {
        background: white;
        border-radius: 15px;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        margin: 20px;
        overflow: hidden;
        border: 1px solid #e9ecef;
    }

    .page-header-bar {
        background: linear-gradient(90deg, #2bb7ff 0%, #00e5ff 100%);
        color: white;
        padding: 14px 18px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
    }

    .page-title {
        margin: 0;
        font-weight: 700;
        font-size: 16px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .table-container {
        padding: 30px;
        background: white;
        overflow-x: hidden;
    }

    .table-responsive-wrapper {
        width: 100%;
        overflow-x: hidden !important;
    }

    .dataTables_wrapper {
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .dataTables_length {
        margin-bottom: 12px;
    }

    #manualEntryTable {
        width: 100% !important;
        border-collapse: separate;
        border-spacing: 0;
        border-radius: 10px;
        overflow: hidden;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
    }

    #manualEntryTable thead th {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        font-weight: 600;
        padding: 10px 12px;
        text-align: center;
        border: none;
        font-size: 12px;
        border-right: 1px solid rgba(255,255,255,0.2);
        white-space: nowrap;
    }

    #manualEntryTable thead th:last-child {
        border-right: none;
    }

    #manualEntryTable tbody td {
        padding: 10px 12px;
        border-bottom: 1px solid #f0f0f0;
        vertical-align: middle;
        text-align: center;
        font-size: 12px;
        white-space: nowrap;
    }

    #manualEntryTable tbody tr:hover {
        background-color: #f8f9ff;
        transform: scale(1.01);
        transition: all 0.2s ease;
    }

    .btn-add {
        background: #ff5b5b;
        color: white;
        border: none;
        padding: 8px 14px;
        border-radius: 20px;
        font-weight: 600;
        text-decoration: none;
        transition: transform 0.2s;
        font-size: 12px;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    .btn-add:hover {
        color: white;
        text-decoration: none;
        transform: translateY(-2px);
    }

    .dataTables_length select {
        border-radius: 20px;
        padding: 5px 15px;
        border: 1px solid #ddd;
    }

    .dataTables_filter input {
        border-radius: 20px;
        padding: 8px 15px;
        border: 1px solid #ddd;
    }

    .dataTables_filter label {
        font-weight: 600;
        color: #495057;
        display: inline-flex;
        align-items: center;
        gap: 10px;
    }

    .dataTables_paginate .paginate_button {
        border-radius: 20px !important;
        padding: 5px 15px !important;
        margin: 0 2px !important;
    }

    .dataTables_paginate .paginate_button.current {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%) !important;
        color: white !important;
        border: none !important;
    }
</style>

<div class="main-container">
    <div class="content-wrapper">
        <div class="page-header-bar">
            <h3 class="page-title">
                <i class="bi bi-vector-pen"></i> Sub Store Manual Stock Entry
            </h3>
            <a href="@Url.Action("Add", "SubStoreDirectManualEntry")" class="btn-add">
                <i class="fa fa-plus"></i> Add Manual Stock Entry
            </a>
        </div>
        <div class="table-container">
            <div class="table-responsive-wrapper">
                <table id="manualEntryTable" class="display table table-striped" cellspacing="0" width="100%">
                    <thead>
                        <tr>
                            <th>Material Group Description</th>
                            <th>Material Description</th>
                            <th>Batch No</th>
                            <th>Expiry Date</th>
                            <th>Closing Quantity</th>
                            <th>P Rate</th>
                            <th>Closing Value</th>
                            <th>Current Batch</th>
                            <th>Physical Quantity</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <style>
        .dme-swal-actions-gap {
            display: flex !important;
            justify-content: center !important;
            gap: 10px !important;
        }

        .dme-swal-actions-gap .swal2-styled {
            margin: 0 !important;
        }
    </style>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        $(document).ready(function () {
            var successMsg = '@(TempData["SuccessMessage"] != null ? TempData["SuccessMessage"].ToString().Replace("\\", "\\\\").Replace("'", "\\'").Replace("\r", "").Replace("\n", " ") : "")';
            if (successMsg && window.Swal && Swal.fire) {
                Swal.fire({
                    icon: 'success',
                    title: successMsg,
                    showConfirmButton: false,
                    timer: 2000,
                    width: 420,
                    buttonsStyling: false
                });
            }

            var initialSearch = '@(ViewBag.DirectManualEntrySearch ?? "")';

            var table = $('#manualEntryTable').DataTable({
                processing: true,
                serverSide: true,
                searching: true,
                paging: true,
                info: true,
                autoWidth: false,
                scrollX: true,
                scrollCollapse: true,
                order: [[1, 'asc']],
                search: { search: initialSearch },
                ajax: {
                    url: '@Url.Action("GetManualEntryData", "SubStoreDirectManualEntry")',
                    type: 'POST'
                },
                columns: [
                    { data: 'MTRLGDESC' },
                    { data: 'MTRLDESC' },
                    { data: 'BATCHNO' },
                    { data: 'STKEDATE' },
                    { data: 'MTRLSTKQTY' },
                    { data: 'STKPRATE' },
                    { data: 'CLVALUE' },
                    { data: 'CURRENTBATCH' },
                    { data: 'PHYQTY' },
                    {
                        data: null,
                        orderable: false,
                        searchable: false,
                        render: function (data, type, row) {
                            var sid = row && row.SID ? row.SID : 0;
                            if (!sid) return '';

                            var editUrl = '@Url.Action("Edit", "SubStoreDirectManualEntry")' + '/' + sid;
                            var html = '';
                            html += '<a href="' + editUrl + '" class="btn btn-sm btn-primary" style="margin-right:6px;">Edit</a>';
                            html += '<button type="button" class="btn btn-sm btn-danger btn-delete" data-id="' + sid + '">Delete</button>';
                            return html;
                        }
                    }
                ],
                columnDefs: [
                    { targets: 0, width: '180px' },
                    { targets: 1, width: '260px' },
                    { targets: 2, width: '120px' },
                    { targets: 3, width: '120px' },
                    { targets: 4, width: '130px' },
                    { targets: 5, width: '100px' },
                    { targets: 6, width: '130px' },
                    { targets: 7, width: '150px' },
                    { targets: 8, width: '140px' },
                    { targets: 9, width: '160px' }
                ],
                language: {
                    search: "Search records:",
                    emptyTable: "No records available"
                }
            });

            $('#manualEntryTable').on('click', '.btn-delete', function () {
                var sid = $(this).data('id');
                if (!sid) return;

                if (window.Swal && Swal.fire) {
                    Swal.fire({
                        icon: 'warning',
                        title: 'Delete this record?',
                        showCancelButton: true,
                        confirmButtonText: 'Yes, Delete',
                        cancelButtonText: 'Cancel',
                        width: 420,
                        buttonsStyling: false,
                        customClass: {
                            actions: 'dme-swal-actions-gap'
                        }
                    }).then(function (result) {
                        if (!result || !result.isConfirmed) return;

                        $.ajax({
                            url: '@Url.Action("Delete", "SubStoreDirectManualEntry")',
                            type: 'POST',
                            data: { id: sid },
                            success: function (res) {
                                if (res && res.ok) {
                                    Swal.fire({
                                        icon: 'success',
                                        title: (res && res.message) ? res.message : 'Deleted Successfully',
                                        showConfirmButton: false,
                                        timer: 1500,
                                        width: 420,
                                        buttonsStyling: false
                                    });
                                    table.ajax.reload(null, false);
                                } else {
                                    Swal.fire({
                                        icon: 'error',
                                        title: (res && res.message) ? res.message : 'Delete failed',
                                        width: 420,
                                        buttonsStyling: false
                                    });
                                }
                            },
                            error: function (xhr) {
                                var msg = (xhr && xhr.responseJSON && xhr.responseJSON.message) ? xhr.responseJSON.message : 'Delete failed';
                                Swal.fire({
                                    icon: 'error',
                                    title: msg,
                                    width: 420,
                                    buttonsStyling: false
                                });
                            }
                        });
                    });
                } else {
                    if (!confirm('Are you sure you want to delete this record?')) return;

                    $.ajax({
                        url: '@Url.Action("Delete", "SubStoreDirectManualEntry")',
                        type: 'POST',
                        data: { id: sid },
                        success: function (res) {
                            if (res && res.ok) {
                                table.ajax.reload(null, false);
                            } else {
                                alert(res && res.message ? res.message : 'Delete failed');
                            }
                        },
                        error: function (xhr) {
                            var msg = (xhr && xhr.responseJSON && xhr.responseJSON.message) ? xhr.responseJSON.message : 'Delete failed';
                            alert(msg);
                        }
                    });
                }
            });
        });
    </script>
}
