@model System.Data.DataTable

@{ 
    ViewBag.Title = "Admin Dashboard - SSK ERP";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var userName = User.Identity.Name;
}

<style>
    .dashboard-sp-table tbody tr:last-child > td,
    .dashboard-sp-table tbody tr:last-child > th {
        font-weight: 700;
        border-width: 2px !important;
    }

    .dashboard-header {
        background: linear-gradient(135deg, #1e88e5 0%, #1565c0 100%);
        color: #fff;
        padding: 18px 20px;
        border-radius: 10px;
        margin-bottom: 15px;
    }

    .dashboard-header h1 {
        margin: 0;
        font-size: 26px;
        font-weight: 700;
        color: #fff;
    }

    .dashboard-header p {
        margin: 6px 0 0 0;
        opacity: 0.95;
    }

    .dashboard-sp-table thead th {
        background: #4fc3f7;
        color: #fff;
        border-color: #29b6f6 !important;
        white-space: normal;
        word-break: break-word;
        line-height: 1.2;
        vertical-align: middle;
    }

    .dashboard-sp-table thead th.col-excess,
    .dashboard-sp-table tbody td.col-excess {
        font-weight: 600;
    }

    .dashboard-sp-table thead th.col-short,
    .dashboard-sp-table tbody td.col-short {
        font-weight: 600;
    }

    .dashboard-sp-table tbody td.col-excess {
        background: #e8f5e9;
        color: #1b5e20;
    }

    .dashboard-sp-table tbody td.col-short {
        background: #ffebee;
        color: #b71c1c;
    }

    .dashboard-sp-table tbody tr:last-child {
        background: #e3f2fd;
    }

    .dashboard-table-title {
        font-weight: 800;
        margin: 0;
        font-size: 16px;
        letter-spacing: 0.5px;
    }

    .dashboard-table-header-row {
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        align-items: center;
        margin: 6px 0 6px 0;
        gap: 10px;
    }

    .dashboard-table-header-row .dashboard-table-title {
        grid-column: 2;
        text-align: center;
    }

    .dashboard-actions {
        grid-column: 3;
        justify-self: end;
        margin: 0;
    }

    .btn-dashboard-pdf {
        background: #d32f2f;
        color: #fff;
        border: none;
        border-radius: 6px;
        padding: 8px 12px;
        font-weight: 700;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    .btn-dashboard-pdf:hover,
    .btn-dashboard-pdf:focus {
        color: #fff;
        text-decoration: none;
        background: #b71c1c;
    }
</style>

<div class="container" style="margin-top:20px;">
    @if (ViewBag.IsDashboardUser != null && (bool)ViewBag.IsDashboardUser)
    {
        <div class="dashboard-header">
            <h1>Admin Dashboard</h1>
            <p>Welcome, @(userName ?? "Administrator")! </p>
        </div>

        if (ViewBag.ErrorMessage != null)
        {
            <div class="alert alert-danger">@ViewBag.ErrorMessage</div>
        }

        if (Model != null && Model.Columns != null && Model.Columns.Count > 0)
        {
            <div class="dashboard-table-header-row">
                <div class="dashboard-table-title">PHARMACY OPENING CLOSING STOCK 2026 - 2027</div>
                <div class="dashboard-actions">
                    <a class="btn-dashboard-pdf" href="@Url.Action("DownloadDashboardPdf", "Home")">
                        <i class="bi bi-download"></i>
                        Download as PDF
                    </a>
                </div>
            </div>

            <div class="table-responsive">
                <table class="table table-bordered table-striped dashboard-sp-table" style="margin-top:15px;">
                    <thead>
                        <tr>
                            @foreach (System.Data.DataColumn col in Model.Columns)
                            {
                                if (string.Equals(col.ColumnName, "MTRLGDESC", StringComparison.OrdinalIgnoreCase))
                                {
                                    <th>Material Group Description (MTRLGDESC)</th>
                                }
                                else if (string.Equals(col.ColumnName, "CLVALUE", StringComparison.OrdinalIgnoreCase))
                                {
                                    <th>Closing Value (CLVALUE)<br />29-03-2026</th>
                                }
                                else if (string.Equals(col.ColumnName, "OPVALUE", StringComparison.OrdinalIgnoreCase))
                                {
                                    <th>Opening Value (OPVALUE)<br />01-04-2026</th>
                                }
                                else if (string.Equals(col.ColumnName, "EXCESS", StringComparison.OrdinalIgnoreCase))
                                {
                                    <th class="col-excess">EXCESS</th>
                                }
                                else if (string.Equals(col.ColumnName, "SHORT", StringComparison.OrdinalIgnoreCase))
                                {
                                    <th class="col-short">SHORT</th>
                                }
                                else
                                {
                                    <th>@col.ColumnName</th>
                                }
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Rows.Count > 0)
                        {
                            foreach (System.Data.DataRow row in Model.Rows)
                            {
                                <tr>
                                    @foreach (System.Data.DataColumn col in Model.Columns)
                                    {
                                        if (string.Equals(col.ColumnName, "EXCESS", StringComparison.OrdinalIgnoreCase))
                                        {
                                            <td class="col-excess">@(row[col] == DBNull.Value ? "" : row[col])</td>
                                        }
                                        else if (string.Equals(col.ColumnName, "SHORT", StringComparison.OrdinalIgnoreCase))
                                        {
                                            <td class="col-short">@(row[col] == DBNull.Value ? "" : row[col])</td>
                                        }
                                        else
                                        {
                                            <td>@(row[col] == DBNull.Value ? "" : row[col])</td>
                                        }
                                    }
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="@Model.Columns.Count" style="text-align:center;">No data available</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            var subStoreTable = ViewBag.SubStoreDashboardTable as System.Data.DataTable;
            if (subStoreTable != null && subStoreTable.Columns != null && subStoreTable.Columns.Count > 0)
            {
                <div class="dashboard-table-header-row" style="margin-top:18px;">
                    <div class="dashboard-table-title">SUB STORE OPENING CLOSING STOCK 2026 - 2027</div>
                </div>

                <div class="table-responsive">
                    <table class="table table-bordered table-striped dashboard-sp-table" style="margin-top:15px;">
                        <thead>
                            <tr>
                                @foreach (System.Data.DataColumn col in subStoreTable.Columns)
                                {
                                    if (string.Equals(col.ColumnName, "MTRLGDESC", StringComparison.OrdinalIgnoreCase))
                                    {
                                        <th>Material Group Description (MTRLGDESC)</th>
                                    }
                                    else if (string.Equals(col.ColumnName, "CLVALUE", StringComparison.OrdinalIgnoreCase))
                                    {
                                        <th>Closing Value (CLVALUE)<br />29-03-2026</th>
                                    }
                                    else if (string.Equals(col.ColumnName, "OPVALUE", StringComparison.OrdinalIgnoreCase))
                                    {
                                        <th>Opening Value (OPVALUE)<br />01-04-2026</th>
                                    }
                                    else if (string.Equals(col.ColumnName, "EXCESS", StringComparison.OrdinalIgnoreCase))
                                    {
                                        <th class="col-excess">EXCESS</th>
                                    }
                                    else if (string.Equals(col.ColumnName, "SHORT", StringComparison.OrdinalIgnoreCase))
                                    {
                                        <th class="col-short">SHORT</th>
                                    }
                                    else
                                    {
                                        <th>@col.ColumnName</th>
                                    }
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @if (subStoreTable.Rows.Count > 0)
                            {
                                foreach (System.Data.DataRow row in subStoreTable.Rows)
                                {
                                    <tr>
                                        @foreach (System.Data.DataColumn col in subStoreTable.Columns)
                                        {
                                            if (string.Equals(col.ColumnName, "EXCESS", StringComparison.OrdinalIgnoreCase))
                                            {
                                                <td class="col-excess">@(row[col] == DBNull.Value ? "" : row[col])</td>
                                            }
                                            else if (string.Equals(col.ColumnName, "SHORT", StringComparison.OrdinalIgnoreCase))
                                            {
                                                <td class="col-short">@(row[col] == DBNull.Value ? "" : row[col])</td>
                                            }
                                            else
                                            {
                                                <td>@(row[col] == DBNull.Value ? "" : row[col])</td>
                                            }
                                        }
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="@subStoreTable.Columns.Count" style="text-align:center;">No data available</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        }
    }
    else
    {
        <div class="dashboard-header">
            <h1>Dashboard</h1>
            <p>Welcome, @(userName ?? "User")! </p>
        </div>

        <div class="row" style="margin-top:15px;">
            <div class="col-md-6">
                <h4 style="margin: 0 0 10px 0; font-weight:700;">Physical Stock Entry</h4>

                <div class="table-responsive">
                    <table class="table table-bordered table-striped">
                        <thead>
                            <tr>
                                <th>Material Group Description</th>
                                <th style="width:120px; text-align:center;">Count</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                var physicalSummary = ViewBag.PhysicalSummary as IEnumerable<HMS_STOCK.Controllers.HomeController.StockEntrySummaryRow>;
                            }

                            @if (physicalSummary != null && physicalSummary.Any())
                            {
                                foreach (var r in physicalSummary)
                                {
                                    <tr>
                                        <td>@(r.MTRLGDESC ?? "")</td>
                                        <td style="text-align:center;">@r.CNT</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="2" style="text-align:center;">No data available</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="col-md-6">
                <h4 style="margin: 0 0 10px 0; font-weight:700;">Manual Stock Entry</h4>

                <div class="table-responsive">
                    <table class="table table-bordered table-striped">
                        <thead>
                            <tr>
                                <th>Material Group Description</th>
                                <th style="width:120px; text-align:center;">Count</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                var manualSummary = ViewBag.ManualSummary as IEnumerable<HMS_STOCK.Controllers.HomeController.StockEntrySummaryRow>;
                            }

                            @if (manualSummary != null && manualSummary.Any())
                            {
                                foreach (var r in manualSummary)
                                {
                                    <tr>
                                        <td>@(r.MTRLGDESC ?? "")</td>
                                        <td style="text-align:center;">@r.CNT</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="2" style="text-align:center;">No data available</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="row" style="margin-top:15px;">
            <div class="col-md-6">
                <h4 style="margin: 0 0 10px 0; font-weight:700;">Sub Store Physical Stock Entry</h4>

                <div class="table-responsive">
                    <table class="table table-bordered table-striped">
                        <thead>
                            <tr>
                                <th>Material Group Description</th>
                                <th style="width:120px; text-align:center;">Count</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                var subStorePhysicalSummary = ViewBag.SubStorePhysicalSummary as IEnumerable<HMS_STOCK.Controllers.HomeController.StockEntrySummaryRow>;
                            }

                            @if (subStorePhysicalSummary != null && subStorePhysicalSummary.Any())
                            {
                                foreach (var r in subStorePhysicalSummary)
                                {
                                    <tr>
                                        <td>@(r.MTRLGDESC ?? "")</td>
                                        <td style="text-align:center;">@r.CNT</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="2" style="text-align:center;">No data available</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="col-md-6">
                <h4 style="margin: 0 0 10px 0; font-weight:700;">Sub Store Manual Stock Entry</h4>

                <div class="table-responsive">
                    <table class="table table-bordered table-striped">
                        <thead>
                            <tr>
                                <th>Material Group Description</th>
                                <th style="width:120px; text-align:center;">Count</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                var subStoreManualSummary = ViewBag.SubStoreManualSummary as IEnumerable<HMS_STOCK.Controllers.HomeController.StockEntrySummaryRow>;
                            }

                            @if (subStoreManualSummary != null && subStoreManualSummary.Any())
                            {
                                foreach (var r in subStoreManualSummary)
                                {
                                    <tr>
                                        <td>@(r.MTRLGDESC ?? "")</td>
                                        <td style="text-align:center;">@r.CNT</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="2" style="text-align:center;">No data available</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>
